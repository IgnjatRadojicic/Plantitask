@page "/groups/{Slug}/{GroupId:guid}"
@layout KanbanLayout
@attribute [Authorize]

@inject IKanbanService KanbanService
@inject IGroupService GroupService
@inject ICurrentUserService CurrentUser
@inject IKanbanSignalRService KanbanSignalR
@inject KanbanLayoutState LayoutState
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IJSRuntime JS

@implements IAsyncDisposable

<KanbanSidebar GroupId="@GroupId" Slug="@Slug" GroupCode="@(_groupDetails?.GroupCode ??"")"/>

<div class="kanban-page">
    <div class="kanban-leaves-bg"></div>
    <div class="kanban-tree-img-wrapper">
        <img src="@_currentTreeImage" alt="" class="kanban-tree-img @(_treeImageClass)" />
        @if (_nextTreeImage is not null)
        {
            <img src="@_nextTreeImage" alt="" class="kanban-tree-img kanban-tree-entering" @onanimationend="OnTreeTransitionEnd" />
        }
    </div>
    <div class="kanban-tree-overlay"></div>

    @if (_loading)
    {
        <div class="field-loading">
            <MudProgressCircular Size="Size.Large" Indeterminate="true" Color="Color.Primary" />
            <p class="text-sora">Loading board...</p>
        </div>
    }
    else if (_errorMessage is not null)
    {
        <div class="field-error">
            <MudIcon Icon="@Icons.Material.Outlined.ErrorOutline" Size="Size.Large" Style="color:#D32F2F;" />
            <p>@_errorMessage</p>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadBoard" Class="auth-btn">
                Try Again
            </MudButton>
        </div>
    }
    else if (_board is not null)
    {
        <div class="kanban-columns-wrapper">
            <div class="kanban-columns">
                @foreach (var column in _board.Columns.OrderBy(c => c.DisplayOrder))
                {
                    <KanbanColumn Column="@column"
                                  SearchTerm="@_activeSearch"
                                  CurrentUserId="@_userInfo.Id"
                                  OnTaskClicked="OpenTaskDetail"
                                  OnQuickCreate="@((int id) => HandleQuickCreate(id))" />
                }
            </div>
        </div>
    }

    @if (_selectedTaskId.HasValue)
    {
        <div class="kanban-overlay kanban-overlay-visible" @onclick="CloseTaskDetail"></div>
        <TaskDetailPanel TaskId="@_selectedTaskId.Value"
                         GroupId="@GroupId"
                         Members="@(_groupDetails?.Members ?? new())"
                         CurrentUserId="@_userInfo.Id"
                         ViewMode="@_detailViewMode"
                         OnClose="CloseTaskDetail"
                         OnViewModeChanged="@(mode => { _detailViewMode = mode; StateHasChanged(); })"
                         OnTaskUpdated="HandleTaskUpdated"
                         OnTaskDeleted="HandleTaskDeleted" />
    }

    <CreateTaskDialog IsOpen="@_createDialogOpen"
                      GroupId="@GroupId"
                      Members="@(_groupDetails?.Members ?? new())"
                      InitialStatusId="@_createInitialStatusId"
                      OnCreated="HandleTaskCreated"
                      OnCancel="CloseCreateDialog" />
</div>

@code {
    [Parameter] public string Slug { get; set; } = "";
    [Parameter] public Guid GroupId { get; set; }

    private bool _loading = true;
    private string? _errorMessage;
    private UserInfo _userInfo = new();
    private KanbanBoardDto? _board;
    private GroupDetailsDto? _groupDetails;
    private DotNetObjectReference<KanbanBoard>? _selfRef;

    private string _activeSearch = "";

    private int _treeStage;
    private string _currentTreeImage = "images/trees/stage-0.png";
    private string? _nextTreeImage;
    private string _treeImageClass = "";

    private bool _createDialogOpen;
    private int _createInitialStatusId = 1;
    private Guid? _selectedTaskId;
    private TaskDetailViewMode _detailViewMode = TaskDetailViewMode.FullScreen;

 

    protected override void OnInitialized()
    {
        KanbanSignalR.OnTaskMoved += HandleRemoteTaskMoved;
        KanbanSignalR.OnTreeUpdated += HandleTreeUpdated;
        LayoutState.OnCreateTaskRequested += HandleLayoutCreateTask;
        LayoutState.OnSearchChanged += HandleLayoutSearch;
        KanbanSignalR.OnTaskCreated += HandleRemoteTaskCreated;
        KanbanSignalR.OnTaskDeleted += HandleRemoteTaskDeleted;
        KanbanSignalR.OnTaskUpdated += HandleRemoteTaskUpdated;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _userInfo = await CurrentUser.GetCurrentUserAsync() ?? new();
        _selfRef = DotNetObjectReference.Create(this);

        await LoadBoard();
        await KanbanSignalR.ConnectAsync(GroupId);
        await JS.InvokeVoidAsync("kanbanDrag.init", _selfRef);
        await JS.InvokeVoidAsync("kanbanTree.observe", _selfRef);
        StateHasChanged();
    }

    private async Task LoadBoard()
    {
        _loading = true;
        _errorMessage = null;
        StateHasChanged();

        var boardTask = KanbanService.GetBoardAsync(GroupId);
        var detailsTask = GroupService.GetGroupDetailsAsync(GroupId);
        await Task.WhenAll(boardTask, detailsTask);

        var boardResult = boardTask.Result;
        var detailsResult = detailsTask.Result;

        if (!boardResult.Success)
        {
            _errorMessage = boardResult.Error;
            _loading = false;
            return;
        }

        _board = boardResult.Data;
        _groupDetails = detailsResult.Success ? detailsResult.Data : null;

        LayoutState.SetGroupInfo(
            GroupId,
            _board?.GroupName ?? "",
            _groupDetails?.Members.Count ?? 0);

        RecalculateTreeStage();
        _loading = false;
    }

    private void HandleLayoutCreateTask()
    {
        _createInitialStatusId = 1;
        _createDialogOpen = true;
        InvokeAsync(StateHasChanged);
    }

    private void HandleLayoutSearch(string term)
    {
        _activeSearch = term;
        InvokeAsync(StateHasChanged);
    }

 

    [JSInvokable]
    public async Task OnCardDropped(string taskId, int newStatusId, int newDisplayOrder)
    {
        if (_board is null || !Guid.TryParse(taskId, out var guid)) return;

        KanbanTaskDto? movedTask = null;
        KanbanColumnDto? sourceCol = null;

        foreach (var col in _board.Columns)
        {
            movedTask = col.Tasks.FirstOrDefault(t => t.Id == guid);
            if (movedTask is not null) { sourceCol = col; break; }
        }

        if (movedTask is null || sourceCol is null) return;

        var targetCol = _board.Columns.FirstOrDefault(c => c.StatusId == newStatusId);
        if (targetCol is null) return;

        if (sourceCol.StatusId == newStatusId)
        {
            var currentIdx = sourceCol.Tasks.IndexOf(movedTask);
            if (currentIdx == newDisplayOrder) return;
        }

        sourceCol.Tasks.Remove(movedTask);
        movedTask.StatusId = newStatusId;
        movedTask.DisplayOrder = newDisplayOrder;
        var insertAt = Math.Clamp(newDisplayOrder, 0, targetCol.Tasks.Count);
        targetCol.Tasks.Insert(insertAt, movedTask);
        ReindexColumn(targetCol);
        if (sourceCol != targetCol) ReindexColumn(sourceCol);

        RecalculateTreeStage();
        StateHasChanged();

        var result = await KanbanService.MoveTaskAsync(guid, new MoveTaskDto
        {
            NewStatusId = newStatusId,
            NewDisplayOrder = newDisplayOrder
        });

        if (!result.Success)
        {
            Snackbar.Add(result.Error ?? "Failed to move task.", MudBlazor.Severity.Error);
            await LoadBoard();
            StateHasChanged();
        }
    }

    private static void ReindexColumn(KanbanColumnDto column)
    {
        var ordered = column.Tasks.OrderBy(t => t.DisplayOrder).ToList();
        for (var i = 0; i < ordered.Count; i++) ordered[i].DisplayOrder = i;
    }



    private void HandleQuickCreate(int statusId)
    {
        _createInitialStatusId = statusId;
        _createDialogOpen = true;
    }

    private void CloseCreateDialog() => _createDialogOpen = false;

    private void HandleTaskCreated(KanbanTaskDto task)
    {
        _createDialogOpen = false;
        _board?.Columns.FirstOrDefault(c => c.StatusId == task.StatusId)?.Tasks.Add(task);
        RecalculateTreeStage();
        StateHasChanged();
    }

    private Task HandleRemoteTaskCreated(KanbanTaskCreatedEvent created)
    {
        if (created.CreatedByUserId == _userInfo.Id) return Task.CompletedTask;
        return InvokeAsync(async () =>
        {
            var result = await KanbanService.GetBoardAsync(GroupId);
            if (result.Success && result.Data is not null)
            {
                _board = result.Data;
                RecalculateTreeStage();
                StateHasChanged();
            }
        });
    }

    private Task HandleRemoteTaskDeleted(KanbanTaskDeletedEvent deleted)
    {
      if (deleted.DeletedByUserId == _userInfo.Id) return Task.CompletedTask;
      return InvokeAsync(() =>
      {
         if (_board is null) return;
         var column = _board.Columns.FirstOrDefault(c => c.StatusId == deleted.StatusId);
         var task = column?.Tasks.FirstOrDefault(t => t.Id == deleted.TaskId);
          if (task is not null)
          {
             column!.Tasks.Remove(task);
             RecalculateTreeStage();
             StateHasChanged();
         }
      });
    }

    private Task HandleRemoteTaskUpdated(KanbanTaskUpdatedEvent updated)
    {
     if (updated.UpdatedByUserId == _userInfo.Id) return Task.CompletedTask;
     return InvokeAsync(async () =>
      {
            var result = await KanbanService.GetBoardAsync(GroupId);
            if (result.Success && result.Data is not null)
            {
               _board = result.Data;
               RecalculateTreeStage();
               StateHasChanged();
          }
     });
    }

    private void OpenTaskDetail(Guid taskId) => _selectedTaskId = taskId;
    private void CloseTaskDetail() => _selectedTaskId = null;

    private void HandleTaskUpdated(TaskItemDto updated)
    {
        if (_board is null) return;
        foreach (var col in _board.Columns)
        {
            var card = col.Tasks.FirstOrDefault(t => t.Id == updated.Id);
            if (card is null) continue;
            if (card.StatusId != updated.StatusId)
            {
                col.Tasks.Remove(card);
                var target = _board.Columns.FirstOrDefault(c => c.StatusId == updated.StatusId);
                if (target is not null) { card.StatusId = updated.StatusId; target.Tasks.Add(card); }
            }
            card.Title = updated.Title;
            card.Description = updated.Description;
            card.PriorityId = updated.PriorityId;
            card.PriorityName = updated.PriorityName;
            card.PriorityColor = updated.PriorityColor ?? "";
            card.AssignedToId = updated.AssignedToId;
            card.AssignedToUserName = updated.AssignedToUserName;
            card.DueDate = updated.DueDate;
            break;
        }
        RecalculateTreeStage();
        StateHasChanged();
    }

    private void HandleTaskDeleted(Guid taskId)
    {
        _selectedTaskId = null;
        if (_board is null) return;
        foreach (var col in _board.Columns)
        {
            var t = col.Tasks.FirstOrDefault(x => x.Id == taskId);
            if (t is not null) { col.Tasks.Remove(t); break; }
        }
        RecalculateTreeStage();
        StateHasChanged();
    }

    private void RecalculateTreeStage()
    {
        if (_board is null) return;

       var total = _board.Columns.Sum(c => c.Tasks.Count);
       if (total == 0) { ApplyTreeStage(1); return; }

       var inProgress = _board.Columns.Where(c => c.StatusId == 2).Sum(c => c.Tasks.Count);
       var underReview = _board.Columns.Where(c => c.StatusId == 3).Sum(c => c.Tasks.Count);
       var completed = _board.Columns.Where(c => c.StatusId == 4).Sum(c => c.Tasks.Count);

        var weighted = (inProgress * 0.33) + (underReview * 0.66) + (completed * 1.0);
        var pct = (weighted / total) * 100.0;
        var stage = pct switch { 0 => 0, < 25 => 0, < 50 => 1, < 100 => 2, >= 100 => 3, _ => 100 };
        ApplyTreeStage(stage);
    }

    private void ApplyTreeStage(int newStage)
    {
        if (newStage == _treeStage && _nextTreeImage is null) return;
        if (_nextTreeImage is not null)
        {
            _currentTreeImage = $"images/trees/stage-{newStage}.png";
            _nextTreeImage = null;
            _treeImageClass = "";
            _treeStage = newStage;
            return;
        }
        _treeStage = newStage;
        _treeImageClass = "kanban-tree-exiting";
        _nextTreeImage = $"images/trees/stage-{newStage}.png";
    }

    [JSInvokable]
    public void OnTreeAnimationEnd()
    {
    if (_nextTreeImage is null) return;
    _currentTreeImage = _nextTreeImage;
    _nextTreeImage = null;
    _treeImageClass = "";
    StateHasChanged();
    }   

    private Task HandleRemoteTaskMoved(KanbanTaskMovedEvent moved)
    {
        if (moved.MovedByUserId == _userInfo.Id) return Task.CompletedTask;
        return InvokeAsync(() =>
        {
            if (_board is null) return;
            KanbanTaskDto? task = null; KanbanColumnDto? source = null;
            foreach (var col in _board.Columns)
            {
                task = col.Tasks.FirstOrDefault(t => t.Id == moved.TaskId);
                if (task is not null) { source = col; break; }
            }
            if (task is null || source is null) return;
            var target = _board.Columns.FirstOrDefault(c => c.StatusId == moved.NewStatusId);
            if (target is null) return;
            source.Tasks.Remove(task);
            task.StatusId = moved.NewStatusId;
            task.DisplayOrder = moved.NewDisplayOrder;
            var idx = Math.Clamp(moved.NewDisplayOrder, 0, target.Tasks.Count);
            target.Tasks.Insert(idx, task);
            ReindexColumn(target);
            if (source != target) ReindexColumn(source);
            RecalculateTreeStage();
            StateHasChanged();
        });
    }

    private Task HandleTreeUpdated(string groupId, int newStage, double pct)
    {
        if (groupId != GroupId.ToString()) return Task.CompletedTask;
        return InvokeAsync(() => { ApplyTreeStage(newStage); StateHasChanged(); });
    }

   

    public async ValueTask DisposeAsync()
    {
        KanbanSignalR.OnTaskMoved -= HandleRemoteTaskMoved;
        KanbanSignalR.OnTreeUpdated -= HandleTreeUpdated;
        LayoutState.OnCreateTaskRequested -= HandleLayoutCreateTask;
        LayoutState.OnSearchChanged -= HandleLayoutSearch;
        KanbanSignalR.OnTaskCreated -= HandleRemoteTaskCreated;
        KanbanSignalR.OnTaskDeleted -= HandleRemoteTaskDeleted;
        KanbanSignalR.OnTaskUpdated -= HandleRemoteTaskUpdated;

        try { await JS.InvokeVoidAsync("kanbanDrag.destroy"); } catch { }
        _selfRef?.Dispose();

        await KanbanSignalR.DisconnectAsync();
    }
}
